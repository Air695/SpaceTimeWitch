  "TANX.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.2-1.next": "继续",
  "TANX.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.2-2.ancient": "[b]尽兴！！[/b]",

  "TEZCATARA.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.0-0.ancient": "过来坐一会吧，亲爱的，让我的火暖暖你。",
  "TEZCATARA.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.0-0.next": "坐下",
  "TEZCATARA.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.0-1.char": "[i][font_size=22]时空魔女享用着特兹卡特拉制作的热可可。[/font_size][/i]",
