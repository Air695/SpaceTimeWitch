  "TANX.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.2-0.ancient": "[b]来！！与我一战！！[/b]",
  "TANX.talk.SPACE_TIME_WITCH_CHARACTER_SPACE_TIME_WITCH.2-0.next": "战斗",
